# Data source: "offline" (CSV/DuckDB backtesting) or "mt5" (live MetaTrader5).
# Default is "offline". Override per-run with --source on the scripts.
DATA_SOURCE=offline

# MT5 credentials (only needed when DATA_SOURCE=mt5, Windows + running terminal)
MT5_LOGIN=your_account_number
MT5_PASSWORD=your_password
MT5_SERVER=your_broker_server_name
